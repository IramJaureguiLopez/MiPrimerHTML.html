<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Login Flow</title>

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #1e1e1e;
}

/* PANTALLAS */
.screen {
  display: none;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.active {
  display: flex;
}

/* CAJAS */
.box {
  background: #d9d9d9;
  padding: 20px;
  border-radius: 6px;
  width: 300px;
}

/* BOTONES LOGIN */
.login-btn {
  display: flex;
  justify-content: center;
  padding: 10px;
  margin: 15px 0;
  border: 1px solid #333;
  border-radius: 5px;
  cursor: pointer;
  background: white;
}

/* FORMULARIO (TU ESTILO ORIGINAL) */
.container {
  width: 350px;
  margin: 40px auto;
  background: #d9d9d9;
  padding: 20px;
  border-radius: 4px;
}

label {
  display: block;
  margin-top: 15px;
  margin-bottom: 5px;
}

input[type="text"] {
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  border: 1px solid #555;
}

.edad-container {
  display: flex;
  align-items: center;
  gap: 10px;
}

.edad-box {
  width: 60px;
  text-align: center;
  padding: 8px;
  border: 1px solid #555;
  border-radius: 5px;
  background: white;
}

.stepper {
  display: flex;
  flex-direction: column;
}

.stepper button {
  width: 35px;
  height: 20px;
  border: 1px solid #555;
  background: white;
  cursor: pointer;
}

.stepper button:active {
  background: #ccc;
}

.genero {
  margin-top: 20px;
}

.genero label {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 8px;
}
</style>
</head>

<body>

<!-- PANTALLA INICIAL -->
<div class="screen active" id="inicio">
  <div class="box">
    <div class="login-btn" onclick="abrirLogin('facebook')">
      Iniciar sesión con Facebook
    </div>

    <div class="login-btn" onclick="abrirLogin('google')">
      Iniciar sesión con Google
    </div>
  </div>
</div>

<!-- LOGIN -->
<div class="screen" id="login">
  <div class="box">
    <h3 id="tituloLogin"></h3>

    <input type="email" placeholder="Escribe tu correo">
    <input type="password" placeholder="Escribe tu contraseña">

    <button onclick="irFormulario()">Iniciar sesión</button>
    <button onclick="volver()">Regresar</button>
  </div>
</div>

<!-- FORMULARIO (TU CÓDIGO) -->
<div class="screen" id="formulario">
  <div class="container">
    <h2>Llenas información</h2>

    <label for="nombre">Nombre:</label>
    <input type="text" id="nombre" placeholder="Escribe tu nombre">

    <label>Edad:</label>
    <div class="edad-container">
      <input type="number" id="edad" class="edad-box" value="0" min="0">
      
      <div class="stepper">
        <button onclick="cambiarEdad(1)">▲</button>
        <button onclick="cambiarEdad(-1)">▼</button>
      </div>
    </div>

    <div class="genero">
      <label>Genero:</label>

      <label>
        <input type="radio" name="genero" value="masculino">
        Masculino
      </label>

      <label>
        <input type="radio" name="genero" value="femenino">
        Femenino
      </label>
    </div>
  </div>
</div>

<script>
function cambiarPantalla(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function abrirLogin(tipo) {
  const titulo = document.getElementById("tituloLogin");
  titulo.textContent = tipo === "facebook" ? "Login con Facebook" : "Login con Google";
  cambiarPantalla("login");
}

function volver() {
  cambiarPantalla("inicio");
}

function irFormulario() {
  cambiarPantalla("formulario");
}

/* TU FUNCIÓN ORIGINAL */
function cambiarEdad(valor) {
  const input = document.getElementById("edad");
  let edad = parseInt(input.value) || 0;

  edad += valor;
  if (edad < 0) edad = 0;

  input.value = edad;
}
</script>

</body>
</html>
